{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(pnpm install*)",
      "Bash(pnpm dev*)",
      "Bash(pnpm build*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm clean*)",
      "Bash(pnpm changeset*)",
      "Bash(pnpm run *)",
      "Bash(pnpm test*)",
      "Bash(pnpm typecheck*)",
      "Bash(turbo run*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push -u origin*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(docker compose up --build*)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.*.local)",
      "Read(./secrets/**)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(python3 -c 'import sys,json;print(json.load(sys.stdin).get(\"tool_input\",{}).get(\"command\",\"\"))' 2>/dev/null); echo \"$cmd\" | grep -qE '(push --force|push -f |reset --hard|clean -f|drop table|DROP TABLE)' && { echo '[GUARD] Blocked: destructive command. Ask the user first.' >&2; exit 2; } || exit 0",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(python3 -c 'import sys,json;print(json.load(sys.stdin).get(\"tool_input\",{}).get(\"file_path\",\"\"))' 2>/dev/null); [ -n \"$file\" ] && [ -f \"$file\" ] && pnpm prettier --config \"$CLAUDE_PROJECT_DIR/.prettierrc.base.json\" --write --ignore-unknown \"$file\" 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && changes=$(git status --porcelain 2>/dev/null | wc -l); [ \"$changes\" -gt 0 ] && echo \"[SESSION] $changes changed file(s) not committed.\" || echo '[SESSION] Working tree clean.'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
