{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "root",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:admin": "turbo run dev --filter=admin...",
    "dev:web": "turbo run dev --filter=web...",
    "dev:server": "turbo run dev --filter=server...",
    "dev:app": "turbo run dev --filter=admin... --filter=server...",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @sb-codex/db db:generate",
    "db:migrate": "pnpm --filter @sb-codex/db db:migrate",
    "db:studio": "pnpm --filter @sb-codex/db db:studio",
    "seed:superadmin": "pnpm --filter server seed:superadmin",
    "changeset": "changeset",
    "version": "changeset version",
    "build:packages": "turbo run build --filter=./packages/*",
    "release": "pnpm build:packages && changeset publish",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "overrides": {
      "@sb-codex/acl": "workspace:^",
      "@sb-codex/core": "workspace:^",
      "@sb-codex/ui-components": "workspace:^",
      "@sb-codex/api-contracts": "workspace:^",
      "@sb-codex/config": "workspace:^",
      "@sb-codex/db": "workspace:^",
      "@sb-codex/auth": "workspace:^",
      "@sb-codex/jobs": "workspace:^",
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "@types/react": "^19.0.1",
      "@types/react-dom": "^19.0.2",
      "drizzle-orm": ">=0.45.2",
      "vite": ">=7.3.2",
      "happy-dom": ">=20.8.9",
      "rollup": ">=4.59.0",
      "esbuild": ">=0.28.1",
      "flatted": ">=3.4.2",
      "minimatch@^3": "^3.1.4",
      "picomatch@^2": "^2.3.2",
      "picomatch@^4": "^4.0.4",
      "tar": "^7.5.11"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.37.0",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.8",
    "premove": "^4.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^3.2.6"
  }
}
