{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@sb-codex/api-contracts",
  "version": "0.1.0-beta.1",
  "description": "tRPC router, procedures and shared Zod schemas for the sb-codex SaaS starter.",
  "type": "module",
  "license": "MIT",
  "author": "Slim Bouchoucha",
  "keywords": [
    "sb-codex",
    "saas-starter",
    "trpc",
    "zod",
    "api"
  ],
  "homepage": "https://github.com/SB-SLIM/react-app-starter/tree/main/packages/api-contracts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SB-SLIM/react-app-starter.git",
    "directory": "packages/api-contracts"
  },
  "bugs": "https://github.com/SB-SLIM/react-app-starter/issues",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "premove ./dist",
    "build": "tsup --tsconfig tsconfig.json",
    "dev": "tsup --watch --tsconfig tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@sb-codex/db": "workspace:^",
    "superjson": "^2.2.2"
  },
  "peerDependencies": {
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.44.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.44.0",
    "zod": "^4.0.0"
  }
}
