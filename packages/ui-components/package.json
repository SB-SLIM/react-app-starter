{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@sb-codex/ui-components",
  "version": "0.0.1-beta.0",
  "description": "React component library + UIProvider + Tailwind theme.css for the sb-codex SaaS starter.",
  "type": "module",
  "license": "MIT",
  "author": "Slim Bouchoucha",
  "keywords": [
    "sb-codex",
    "saas-starter",
    "react",
    "tailwind",
    "ui",
    "components"
  ],
  "homepage": "https://github.com/SB-SLIM/react-app-starter/tree/main/packages/ui-components#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SB-SLIM/react-app-starter.git",
    "directory": "packages/ui-components"
  },
  "bugs": "https://github.com/SB-SLIM/react-app-starter/issues",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src/theme.css"
  ],
  "scripts": {
    "clean": "premove ./dist",
    "build": "tsup --tsconfig tsconfig.json",
    "dev": "tsup --watch --tsconfig tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./theme.css": "./src/theme.css"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@sb-codex/core": "workspace:^",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react-datepicker": "^9.1.0",
    "react-select": "^5.10.2",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "tailwindcss": "^4.3.0"
  }
}
