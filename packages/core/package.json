{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@sb-codex/core",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "premove ./dist",
    "build": "tsup --tsconfig tsconfig.json",
    "dev": "tsup --watch --tsconfig tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "clsx": "^2.1.1"
  }
}
