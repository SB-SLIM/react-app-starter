{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@sb-codex/config",
  "version": "0.0.1-beta.0",
  "description": "Zod-validated environment loader (createEnv) for the sb-codex SaaS starter.",
  "type": "module",
  "license": "MIT",
  "author": "Slim Bouchoucha",
  "keywords": [
    "sb-codex",
    "saas-starter",
    "env",
    "zod",
    "config"
  ],
  "homepage": "https://github.com/SB-SLIM/react-app-starter/tree/main/packages/config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SB-SLIM/react-app-starter.git",
    "directory": "packages/config"
  },
  "bugs": "https://github.com/SB-SLIM/react-app-starter/issues",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "premove ./dist",
    "build": "tsup --tsconfig tsconfig.json",
    "dev": "tsup --watch --tsconfig tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "zod": "^4.0.0"
  }
}
