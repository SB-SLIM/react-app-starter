{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@sb-codex/auth",
  "version": "0.0.1-beta.1",
  "description": "better-auth server config (createAuth) + library-agnostic client facade for the sb-codex SaaS starter.",
  "type": "module",
  "license": "MIT",
  "author": "Slim Bouchoucha",
  "keywords": [
    "sb-codex",
    "saas-starter",
    "better-auth",
    "auth",
    "organizations",
    "multi-tenant"
  ],
  "homepage": "https://github.com/SB-SLIM/react-app-starter/tree/main/packages/auth#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SB-SLIM/react-app-starter.git",
    "directory": "packages/auth"
  },
  "bugs": "https://github.com/SB-SLIM/react-app-starter/issues",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "premove ./dist",
    "build": "tsup --tsconfig tsconfig.json",
    "dev": "tsup --watch --tsconfig tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    }
  },
  "dependencies": {
    "@sb-codex/db": "workspace:^",
    "better-auth": "^1.0.0"
  }
}
