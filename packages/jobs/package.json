{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@sb-codex/jobs",
  "version": "0.1.0-beta.1",
  "description": "BullMQ queue definitions + worker entrypoint for the sb-codex SaaS starter.",
  "type": "module",
  "license": "MIT",
  "author": "Slim Bouchoucha",
  "keywords": [
    "sb-codex",
    "saas-starter",
    "bullmq",
    "queue",
    "worker",
    "jobs"
  ],
  "homepage": "https://github.com/SB-SLIM/react-app-starter/tree/main/packages/jobs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SB-SLIM/react-app-starter.git",
    "directory": "packages/jobs"
  },
  "bugs": "https://github.com/SB-SLIM/react-app-starter/issues",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "premove ./dist",
    "build": "tsup --tsconfig tsconfig.json",
    "dev": "tsup --watch --tsconfig tsconfig.json",
    "worker": "tsx src/worker.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "bullmq": "^5.0.0",
    "ioredis": "^5.6.1",
    "meilisearch": "^0.58.0",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.19.0"
  }
}
