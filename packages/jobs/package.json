{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@sb-codex/jobs",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "premove ./dist",
    "build": "tsup --tsconfig tsconfig.json",
    "dev": "tsup --watch --tsconfig tsconfig.json",
    "worker": "tsx src/worker.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "bullmq": "^5.0.0",
    "ioredis": "^5.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0"
  }
}
