{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@sb-codex/db",
  "version": "0.1.0-beta.1",
  "description": "Drizzle ORM schema, migrations, RLS helpers and createDb() for the sb-codex SaaS starter.",
  "type": "module",
  "license": "MIT",
  "author": "Slim Bouchoucha",
  "keywords": [
    "sb-codex",
    "saas-starter",
    "drizzle",
    "postgres",
    "rls",
    "multi-tenant"
  ],
  "homepage": "https://github.com/SB-SLIM/react-app-starter/tree/main/packages/db#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SB-SLIM/react-app-starter.git",
    "directory": "packages/db"
  },
  "bugs": "https://github.com/SB-SLIM/react-app-starter/issues",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "premove ./dist",
    "build": "tsup --tsconfig tsconfig.json",
    "dev": "tsup --watch --tsconfig tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "postgres": "^3.4.5"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.44.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.0",
    "drizzle-orm": "^0.44.0",
    "tsx": "^4.19.0",
    "vitest": "^3.2.4"
  }
}
