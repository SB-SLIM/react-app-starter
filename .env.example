# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Direct connection (used by Drizzle migrations)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas
# PgBouncer pooled connection (used by the app at runtime)
# DATABASE_URL=postgresql://app:app_password@localhost:5433/saas

# ── Valkey / Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── better-auth ───────────────────────────────────────────────────────────────
# Must be at least 32 characters
BETTER_AUTH_SECRET=change-me-in-production-must-be-32-chars
BETTER_AUTH_URL=http://localhost:3001

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Admin Vite app ────────────────────────────────────────────────────────────
VITE_TRPC_URL=http://localhost:3001/trpc
