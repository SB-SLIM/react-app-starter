# ─────────────────────────────────────────────────────────────────────────────
# sb-codex monorepo — environment variables
# Copy to .env and fill in values. Defaults below work with the local
# docker compose stack (infra/compose/docker-compose.yml).
# Production values go in .env.production on the VPS (never committed).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Superuser URL — used by migrations only (bypasses RLS). Never used at runtime.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas

# Non-privileged `app` role password — used by apps/server at runtime.
# The app role enforces RLS. Created by infra/compose/init/01_init.sh.
APP_DB_PASSWORD=app_password

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=saas

# ── Redis / Valkey ────────────────────────────────────────────────────────────
REDIS_URL=redis://:changeme_valkey@localhost:6379
VALKEY_PASSWORD=changeme_valkey

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be 32+ characters. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-in-development-must-be-32-chars!!

# Full public URL of the API server (used by better-auth for OAuth callbacks)
BETTER_AUTH_URL=http://localhost:3001

# Allowed origins for CORS — comma-separated, no trailing slash
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ── OAuth (optional) ──────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── SMTP / Email ──────────────────────────────────────────────────────────────
# Dev: MailHog listens on port 1025 (UI at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ── MinIO (object storage) ────────────────────────────────────────────────────
# Console UI at http://localhost:9001 in dev
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio

# ── Meilisearch (full-text search) ───────────────────────────────────────────
# Generate: openssl rand -hex 32
MEILI_MASTER_KEY=changeme_meili_master_key

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# ── Vite SPAs (baked at build time — changing requires a full rebuild) ────────
VITE_TRPC_URL=http://localhost:3001/api/trpc
VITE_BETTER_AUTH_URL=http://localhost:3001

# ── Production deployment (VPS only — not needed for local dev) ───────────────
# DOMAIN=yourdomain.com
# GHCR_IMAGE_PREFIX=ghcr.io/your-org/your-repo
# IMAGE_TAG=latest

# ── Superadmin bootstrap (run once via: pnpm seed:superadmin) ─────────────────
# SUPERADMIN_PASSWORD=changeme_strong_password
