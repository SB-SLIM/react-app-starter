# Copy to .env and fill in. Dev defaults below work with the local
# docker-compose stack (postgres + valkey on localhost).

# Database (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas

# Cache / queue (Valkey / Redis)
REDIS_URL=redis://localhost:6379

# Auth (better-auth) — secret must be 32+ chars in production
BETTER_AUTH_SECRET=change-me-in-development-must-be-32-chars!!
BETTER_AUTH_URL=http://localhost:3001

# CORS — admin app origin
CORS_ORIGIN=http://localhost:5173

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
